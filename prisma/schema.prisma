generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      =  env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TipoTorneo {
  AMERICANO
  LARGO
}

enum Deporte {
  PADEL
  FUTBOL
  TENIS
}

enum Formato {
  AMERICANO
  LARGO
  LIGA
}

enum CategoriaPadel {
  TERCERA
  CUARTA
  TERCERA_CUARTA
  QUINTA
  SEXTA
  QUINTA_SEXTA
  SEPTIMA
  SEXTA_SEPTIMA
  OCTAVA
  NOVENA
  OCTAVA_NOVENA
}

enum EstadoTorneo {
  CONFIGURACION
  GRUPOS
  RANKING
  DESEMPATE
  ELIMINATORIA
  FINALIZADO
}

enum MetodoDesempate {
  MONEDA
  TIEBREAK
}

enum FaseGrupo {
  RONDA1
  RONDA2
}

enum TipoParticipante {
  INDIVIDUAL
  PAREJA
  EQUIPO
}

enum FasePartido {
  GRUPOS
  FECHAS
  ELIMINATORIA
}

enum EstadoPartido {
  PENDIENTE
  EN_JUEGO
  FINALIZADO
  WALKOVER
}

enum TipoEventoPartido {
  GOL
  ASISTENCIA
  AMARILLA
  ROJA
  MVP
  ACE
  WINNER
  ERROR_NO_FORZADO
}

enum EstadoFechaCompetencia {
  PROGRAMADA
  EN_CURSO
  CERRADA
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  torneos      Torneo[]
  sessions     AuthSession[]
}

model Torneo {
  id              String           @id @default(cuid())
  userId          String
  nombre          String
  deporte         Deporte          @default(PADEL)
  formato         Formato          @default(AMERICANO)
  categoriaPadel  CategoriaPadel?
  config          Json?
  tipo            TipoTorneo
  estado          EstadoTorneo     @default(CONFIGURACION)
  cantidadCanchas Int              @default(2)
  metodoDesempate MetodoDesempate
  fecha           DateTime
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parejas         Pareja[]
  grupos          Grupo[]
  bracket         Bracket?
  desempates      Desempate[]
  participantes   Participante[]
  jugadores       Jugador[]
  partidos        Partido[]
  eventos         EventoPartido[]
  fechas          FechaCompetencia[]
  rankingConfig   RankingConfig?

  @@index([userId, deporte, formato, estado, createdAt])
}

model Pareja {
  id               String         @id @default(cuid())
  torneoId         String
  grupoId          String?
  nombre           String
  jugador1         String?
  jugador2         String?
  seed             Int?
  torneo           Torneo         @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  grupo            Grupo?         @relation(fields: [grupoId], references: [id], onDelete: SetNull)
  partidosComoP1   PartidoGrupo[] @relation("PartidoGrupoPareja1")
  partidosComoP2   PartidoGrupo[] @relation("PartidoGrupoPareja2")
  bracketComoP1    BracketMatch[] @relation("BracketMatchPareja1")
  bracketComoP2    BracketMatch[] @relation("BracketMatchPareja2")
  bracketGanados   BracketMatch[] @relation("BracketMatchGanador")
  desempatesComoP1 Desempate[]    @relation("DesempatePareja1")
  desempatesComoP2 Desempate[]    @relation("DesempatePareja2")
  desempatesGanado Desempate[]    @relation("DesempateGanador")
}

model Grupo {
  id            String         @id @default(cuid())
  torneoId      String
  nombre        String
  torneo        Torneo         @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  parejas       Pareja[]
  participantes Participante[]
  partidos      PartidoGrupo[]
  partidosV2    Partido[]
}

model PartidoGrupo {
  id           String    @id @default(cuid())
  grupoId      String
  fase         FaseGrupo
  orden        Int
  pareja1Id    String
  pareja2Id    String
  gamesPareja1 Int?
  gamesPareja2 Int?
  scoreJson    Json?
  walkover     Boolean   @default(false)
  completado   Boolean   @default(false)
  grupo        Grupo     @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  pareja1      Pareja    @relation("PartidoGrupoPareja1", fields: [pareja1Id], references: [id], onDelete: Restrict)
  pareja2      Pareja    @relation("PartidoGrupoPareja2", fields: [pareja2Id], references: [id], onDelete: Restrict)

  @@unique([grupoId, fase, orden])
}

model Bracket {
  id          String         @id @default(cuid())
  torneoId    String         @unique
  tamano      Int
  totalRondas Int
  torneo      Torneo         @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  matches     BracketMatch[]
  partidosV2  Partido[]
}

model BracketMatch {
  id           String   @id @default(cuid())
  bracketId    String
  ronda        Int
  posicion     Int
  esBye        Boolean  @default(false)
  pareja1Id    String?
  pareja2Id    String?
  ganadorId    String?
  gamesPareja1 Int?
  gamesPareja2 Int?
  scoreJson    Json?
  walkover     Boolean  @default(false)
  completado   Boolean  @default(false)
  bracket      Bracket  @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  pareja1      Pareja?  @relation("BracketMatchPareja1", fields: [pareja1Id], references: [id], onDelete: SetNull)
  pareja2      Pareja?  @relation("BracketMatchPareja2", fields: [pareja2Id], references: [id], onDelete: SetNull)
  ganador      Pareja?  @relation("BracketMatchGanador", fields: [ganadorId], references: [id], onDelete: SetNull)

  @@unique([bracketId, ronda, posicion])
}

model Desempate {
  id        String          @id @default(cuid())
  torneoId  String
  pareja1Id String
  pareja2Id String
  ganadorId String?
  metodo    MetodoDesempate
  resuelto  Boolean         @default(false)
  torneo    Torneo          @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  pareja1   Pareja          @relation("DesempatePareja1", fields: [pareja1Id], references: [id], onDelete: Restrict)
  pareja2   Pareja          @relation("DesempatePareja2", fields: [pareja2Id], references: [id], onDelete: Restrict)
  ganador   Pareja?         @relation("DesempateGanador", fields: [ganadorId], references: [id], onDelete: SetNull)
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model LoginRateLimit {
  keyHash         String   @id
  attempts        Int
  windowStartedAt DateTime
  blockedUntil    DateTime?
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expiresAt])
  @@index([blockedUntil])
}

model Participante {
  id                 String         @id @default(cuid())
  torneoId           String
  grupoId            String?
  nombre             String
  tipo               TipoParticipante
  escudo             String?
  seed               Int?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  torneo             Torneo         @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  grupo              Grupo?         @relation(fields: [grupoId], references: [id], onDelete: SetNull)
  jugadores          Jugador[]
  partidosComoLocal  Partido[]      @relation("PartidoLocal")
  partidosComoVisit  Partido[]      @relation("PartidoVisitante")
  partidosGanados    Partido[]      @relation("PartidoGanador")
  eventos            EventoPartido[] @relation("EventoPartidoParticipante")

  @@index([torneoId, tipo, seed])
}

model Jugador {
  id             String          @id @default(cuid())
  torneoId       String
  participanteId String?
  nombre         String
  apodo          String?
  dorsal         Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  torneo         Torneo          @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  participante   Participante?   @relation(fields: [participanteId], references: [id], onDelete: SetNull)
  eventos        EventoPartido[] @relation("EventoPartidoJugador")

  @@index([torneoId, participanteId])
  @@index([torneoId, nombre])
}

model Partido {
  id                String           @id @default(cuid())
  torneoId          String
  grupoId           String?
  bracketId         String?
  fechaId           String?
  fase              FasePartido      @default(GRUPOS)
  ronda             Int?
  orden             Int?
  localId           String?
  visitanteId       String?
  ganadorId         String?
  estado            EstadoPartido    @default(PENDIENTE)
  walkover          Boolean          @default(false)
  completado        Boolean          @default(false)
  golesLocal        Int?
  golesVisitante    Int?
  penalesLocal      Int?
  penalesVisitante  Int?
  set1Local         Int?
  set1Visitante     Int?
  set2Local         Int?
  set2Visitante     Int?
  set3Local         Int?
  set3Visitante     Int?
  tiebreak3Local    Int?
  tiebreak3Visitante Int?
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  torneo            Torneo           @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  grupo             Grupo?           @relation(fields: [grupoId], references: [id], onDelete: SetNull)
  bracket           Bracket?         @relation(fields: [bracketId], references: [id], onDelete: SetNull)
  fecha             FechaCompetencia? @relation(fields: [fechaId], references: [id], onDelete: SetNull)
  local             Participante?    @relation("PartidoLocal", fields: [localId], references: [id], onDelete: SetNull)
  visitante         Participante?    @relation("PartidoVisitante", fields: [visitanteId], references: [id], onDelete: SetNull)
  ganador           Participante?    @relation("PartidoGanador", fields: [ganadorId], references: [id], onDelete: SetNull)
  eventos           EventoPartido[]

  @@index([torneoId, estado, fase])
  @@index([torneoId, fechaId, ronda])
  @@index([localId])
  @@index([visitanteId])
  @@index([ganadorId])
}

model EventoPartido {
  id             String             @id @default(cuid())
  torneoId       String
  partidoId      String
  jugadorId      String?
  participanteId String?
  tipo           TipoEventoPartido
  minuto         Int?
  descripcion    String?
  createdAt      DateTime           @default(now())
  torneo         Torneo             @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  partido        Partido            @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  jugador        Jugador?           @relation("EventoPartidoJugador", fields: [jugadorId], references: [id], onDelete: SetNull)
  participante   Participante?      @relation("EventoPartidoParticipante", fields: [participanteId], references: [id], onDelete: SetNull)

  @@index([torneoId, tipo, createdAt])
  @@index([partidoId, tipo])
  @@index([jugadorId, tipo])
}

model FechaCompetencia {
  id        String                 @id @default(cuid())
  torneoId  String
  numero    Int
  inicio    DateTime?
  fin       DateTime?
  estado    EstadoFechaCompetencia @default(PROGRAMADA)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  torneo    Torneo                 @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  partidos  Partido[]

  @@unique([torneoId, numero])
  @@index([torneoId, estado, inicio])
}

model RankingConfig {
  torneoId            String   @id
  campeon             Int      @default(100)
  subcampeon          Int      @default(70)
  semifinalista       Int      @default(50)
  cuartofinalista     Int      @default(35)
  octavos             Int      @default(20)
  dieciseisavos       Int      @default(10)
  faseGrupos          Int      @default(5)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  torneo              Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
}
