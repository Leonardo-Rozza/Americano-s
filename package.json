{
  "name": "torneos-americanos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "prisma:generate": "node --env-file=.env ./node_modules/prisma/build/index.js generate",
    "prisma:db:push": "node --env-file=.env ./node_modules/prisma/build/index.js db push",
    "prisma:migrate:deploy": "node --env-file=.env ./node_modules/prisma/build/index.js migrate deploy",
    "prisma:studio": "node --env-file=.env ./node_modules/prisma/build/index.js studio",
    "backfill:parejas": "node --env-file=.env prisma/backfill-parejas.mjs",
    "seed:user": "node --env-file=.env prisma/seed-user.mjs",
    "user:create": "node --env-file=.env prisma/create-user.mjs"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.16.0",
    "jose": "^6.2.0",
    "next": "16.1.6",
    "prisma": "^6.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
